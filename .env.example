# MongoDB Configuration
MONGODB_URI=mongodb://mongodb:27017/nbfc_loan_platform
MONGODB_DB_NAME=nbfc_loan_platform

# Redis Configuration
REDIS_URL=redis://redis:6379

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production-use-strong-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Encryption Configuration (Generate using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-fernet-encryption-key-here

# Application URLs
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Environment
ENVIRONMENT=development

# OTP Configuration
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3

# Rate Limiting
RATE_LIMIT_OTP_PER_15MIN=3

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
